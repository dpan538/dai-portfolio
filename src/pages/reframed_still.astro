---
import BaseLayout from "../layouts/base_layout.astro";

const page_title = "Reframed Still";
const page_description =
    "A photographic sequence that reframes stillness through a curated strip of images, slowing the gaze across cities and time.";

const images = Array.from({ length: 8 }, (_, i) => {
    const n = String(i + 1).padStart(2, "0");
    return `/projects/reframed_still/reframed${n}.jpg`;
});

const SITE_URL = "https://daipan.art";
const meta = {
    title: page_title,
    description: page_description,
    og_image: images[0],
    canonical: `${SITE_URL}/reframed_still`,
};
const breadcrumbs = [{ name: "Home", url: SITE_URL }, { name: "Reframed Still", url: `${SITE_URL}/reframed_still` }];

const project = {
    title: "Reframed Still",
    medium: "Gelatin Silver Print",
    locations: ["New York", "Guangzhou", "Shanghai", "Nantong"],
    years: "2021 — 2025",
    note: "A sequence that reframes stillness through a curated strip of images, slowing the gaze across cities and time. Moments of quiet and pause within the flow of urban life; light, shadow, and composition unfold gradually as one moves through the strip.",
};

const frameHints = [
    "A pause in the flow.",
    "Light through the window.",
    "Evening.",
    "Still.",
    "Between cities.",
    "A moment held.",
    "Light and shadow.",
    "Where the gaze rests.",
];
---

<BaseLayout
    title={page_title}
    description={page_description}
    canonical={meta.canonical}
    ogImage={meta.og_image}
    ogType="article"
    active="reframed_still"
    breadcrumbs={breadcrumbs}>

    <!-- Desktop: backup 7a49036 的 strip/desc_panel 结构 -->
    <div class="reframed-desktop">
        <div class="reframed-page reframed-page--desktop">
            <p class="strip-intro-hint" aria-hidden="true">Scroll to drift through the strip · Hover for a note</p>
            <div class="strip-wrap">
                <section class="strip" id="reframed-strip-desktop" tabindex={0}>
                    {images.map((src, idx) => (
                        <figure class="frame" data-index={idx} data-hint={frameHints[idx] ?? ""}>
                            <img
                                class="lb_img"
                                src={src}
                                data-index={idx}
                                alt={`Reframed Still — frame ${idx + 1}`}
                                loading={idx < 2 ? "eager" : "lazy"}
                                decoding="async"
                            />
                        </figure>
                    ))}
                    <div class="lightbox lightbox-desktop" aria-hidden="true">
                        <div class="lb_backdrop" data-close="1"></div>
                        <div class="lb_stage" role="dialog" aria-modal="true" aria-label="Image preview">
                            <button class="lb_btn lb_close" type="button" aria-label="Close" data-close="1">×</button>
                            <button class="lb_btn lb_prev" type="button" aria-label="Previous">‹</button>
                            <figure class="lb_figure">
                                <img class="lb_view" src="" alt="" />
                            </figure>
                            <button class="lb_btn lb_next" type="button" aria-label="Next">›</button>
                        </div>
                    </div>
                    <article class="desc_panel">
                        <h3>{project.title}</h3>
                        <div class="meta">
                            <div><strong>Medium:</strong> {project.medium}</div>
                            <div><strong>Location:</strong> {project.locations.join(", ")}</div>
                            <div><strong>Year:</strong> {project.years}</div>
                        </div>
                        <p>{project.note}</p>
                    </article>
                </section>
                <div class="strip-hint-bar" aria-live="polite">
                    <span aria-hidden="true">←</span>
                    <span id="reframed-hint-text-desktop">Use ←/→ to scroll · Hover for a note</span>
                    <span aria-hidden="true">→</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile: 当前满意的布局 -->
    <div class="reframed-mobile">
        <div class="reframed-page reframed-page--mobile">
            <div class="strip-wrap">
                <section class="strip" id="reframed-strip" tabindex={0}>
                    {images.map((src, idx) => (
                        <figure class="frame" data-index={idx} data-hint={frameHints[idx] ?? ""}>
                            <img
                                class="lb_img"
                                src={src}
                                data-index={idx}
                                alt={`Reframed Still — frame ${idx + 1}`}
                                loading={idx < 2 ? "eager" : "lazy"}
                                decoding="async"
                            />
                        </figure>
                    ))}
                </section>
                <div class="strip-hint-bar" aria-live="polite">
                    <span aria-hidden="true">←</span>
                    <span id="reframed-hint-text">Swipe or click to browse</span>
                    <span aria-hidden="true">→</span>
                </div>
            </div>
            <div class="lightbox lightbox-mobile" id="reframed-lightbox" aria-hidden="true">
                <div class="lb_backdrop" data-close="1"></div>
                <div class="lb_inner" role="dialog" aria-modal="true" aria-label="Image preview">
                    <img class="lb_view" src="" alt="" />
                    <div class="lb_controls">
                        <button class="lb_btn lb_prev" type="button" aria-label="Previous">←</button>
                        <button class="lb_btn lb_close" type="button" aria-label="Close" data-close="1">✕</button>
                        <button class="lb_btn lb_next" type="button" aria-label="Next">→</button>
                    </div>
                </div>
            </div>
            <article class="reframed-desc">
                <div class="meta">
                    <div><strong>Medium:</strong> {project.medium}</div>
                    <div><strong>Location:</strong> {project.locations.join(", ")}</div>
                    <div><strong>Year:</strong> {project.years}</div>
                </div>
                <p>{project.note}</p>
            </article>
        </div>
    </div>
</BaseLayout>

<style>
    :root {
        --bg: #ffffff;
        --fg: #111111;
        --muted: rgba(0, 0, 0, 0.62);
        --muted2: rgba(0, 0, 0, 0.52);
        --line: #e9e9e9;
        --gap: 56px;
        --strip_h: 72vh;
        --side_pad: 10vw;
    }

    body { margin: 0; background: var(--bg); color: var(--fg); overflow-x: hidden; }

    .reframed-desktop { display: none; }
    .reframed-mobile { display: block; overflow-x: hidden; }
    @media (min-width: 769px) {
        .reframed-desktop { display: block; }
        .reframed-mobile { display: none; }
    }

    /* ========== Desktop (≥769px)：backup 7a49036 样式 ========== */
    @media (min-width: 769px) {
        :global(main.content:has(.reframed-desktop)) {
            padding: 0 !important;
            max-width: none !important;
            margin-inline: 0 !important;
            height: 100vh !important;
            overflow: hidden !important;
            padding-top: 88px !important;
            padding-bottom: 48px !important;
        }
        :global(main.content > *) { max-width: none !important; }

        .reframed-page--desktop {
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100%;
        }
        .strip-intro-hint {
            flex-shrink: 0;
            margin: 0 0 16px;
            margin-top: -12px;
            font-size: 0.8rem;
            color: var(--muted);
            text-align: center;
        }
        .reframed-desktop .strip-wrap {
            flex: 1;
            min-height: 0;
            overflow: hidden;
        }
        .reframed-desktop .strip {
            height: 100%;
            display: flex;
            align-items: flex-start;
            padding: 16px clamp(24px, 6vw, 72px);
            overflow-x: auto;
            overflow-y: hidden;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
            gap: var(--gap);
        }
        .reframed-desktop .strip::-webkit-scrollbar { height: 10px; }
        .reframed-desktop figure.frame {
            margin: 0;
            height: 86vh;
            flex: 0 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .reframed-desktop figure.frame img {
            height: 100%;
            width: auto;
            max-height: var(--strip_h);
            border: 1px solid transparent;
            box-sizing: border-box;
        }
        .reframed-desktop figure.frame:hover img { border-color: var(--line); }
        .reframed-desktop .strip-hint-bar {
            position: fixed;
            bottom: 48px;
            left: 320px;
            right: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 22px;
            padding: 10px 0;
            z-index: 10;
        }
        .reframed-desktop .strip-hint-bar span { font-size: 0.8rem; color: var(--muted); }
        #reframed-hint-text-desktop { min-width: 12ch; }
        @media (max-width: 820px) {
            .reframed-desktop .strip-hint-bar { left: 0; bottom: 24px; }
        }
        .reframed-desktop .strip::after {
            content: "";
            flex: 0 0 clamp(24px, 6vw, 96px);
        }
        .reframed-desktop .desc_panel {
            flex: 0 0 auto;
            height: 72vh;
            width: min(560px, 78vw);
            position: relative;
            background: transparent;
            padding: 72px 40px 40px 40px;
            box-sizing: border-box;
        }
        .reframed-desktop .desc_panel::before {
            content: "";
            position: absolute;
            inset: -14px;
            pointer-events: none;
            background: radial-gradient(closest-side, rgba(0, 0, 0, 0.06), rgba(0, 0, 0, 0) 70%);
            border-radius: 18px;
        }
        .reframed-desktop .desc_panel h3 { font-size: 1rem; font-weight: 600; margin: 0 0 12px; letter-spacing: 0.04em; }
        .reframed-desktop .desc_panel .meta { font-size: 0.85rem; line-height: 1.6; margin-bottom: 16px; color: var(--muted); }
        .reframed-desktop .desc_panel .meta strong { color: var(--fg); font-weight: 600; }
        .reframed-desktop .desc_panel p { font-size: 0.9rem; line-height: 1.75; color: var(--muted2); margin: 0; }
        .reframed-desktop .strip:focus { outline: none; }
        .reframed-desktop .strip:focus-visible { outline: 1px solid var(--line); outline-offset: 2px; }

        .lightbox-desktop {
            position: fixed;
            inset: 0;
            display: none;
            z-index: 999;
        }
        .lightbox-desktop.is_open { display: block; }
        .lightbox-desktop .lb_backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.82);
            cursor: zoom-out;
        }
        .lightbox-desktop .lb_stage {
            position: relative;
            width: 100%;
            height: 100%;
            display: grid;
            grid-template-columns: 64px 1fr 64px;
            align-items: center;
        }
        .lightbox-desktop .lb_figure {
            margin: 0;
            display: grid;
            place-items: center;
            height: 100%;
        }
        .lightbox-desktop .lb_view {
            max-width: min(92vw, 1200px);
            max-height: 86vh;
            width: auto;
            height: auto;
            object-fit: contain;
            background: rgba(255, 255, 255, 0.02);
        }
        .lightbox-desktop .lb_btn {
            appearance: none;
            border: 0;
            background: transparent;
            color: rgba(255, 255, 255, 0.86);
            font-size: 42px;
            line-height: 1;
            cursor: pointer;
            height: 64px;
            width: 64px;
            display: grid;
            place-items: center;
            user-select: none;
        }
        .lightbox-desktop .lb_btn:hover { color: rgba(255, 255, 255, 1); }
        .lightbox-desktop .lb_close {
            position: absolute;
            top: 18px;
            right: 18px;
            font-size: 34px;
            width: 44px;
            height: 44px;
        }
        .reframed-desktop .lb_img { cursor: zoom-in; }
    }

    /* ========== Mobile (≤768px)：当前样式 ========== */
    @media (max-width: 768px) {
        :global(body:has(main.content:has(.reframed-mobile)) .shell) {
            min-height: auto;
        }
        :global(main.content:has(.reframed-mobile)) {
            padding: 0 !important;
            padding-top: 142px !important;
            padding-bottom: max(48px, env(safe-area-inset-bottom, 0px)) !important;
            padding-inline: 26px !important;
            max-width: none !important;
            margin-inline: 0 !important;
            height: auto !important;
            min-height: auto !important;
            overflow-x: hidden !important;
            overflow-y: auto !important;
        }
        :global(main.content > *) { max-width: none !important; }
    }

    .reframed-page--mobile {
        display: flex;
        flex-direction: column;
        width: 100%;
        min-height: auto;
        overflow-x: hidden;
    }
    .reframed-mobile .strip-wrap {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0;
    }
    .reframed-mobile .strip {
        width: 100%;
        max-width: min(900px, 100%);
        height: 36vh;
        display: flex;
        align-items: flex-start;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        padding: 0 clamp(24px, 6vw, 48px);
        gap: 28px;
        touch-action: pan-x;
    }
    .reframed-mobile .strip::-webkit-scrollbar { display: none; height: 0; }
    .reframed-mobile .strip { -ms-overflow-style: none; scrollbar-width: none; }
    .reframed-mobile figure.frame {
        margin: 0;
        height: 36vh;
        flex: 0 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .reframed-mobile figure.frame img {
        height: 100%;
        width: auto;
        border: 1px solid transparent;
        box-sizing: border-box;
    }
    .reframed-mobile figure.frame:hover img { border-color: var(--line); }
    .reframed-mobile .strip-hint-bar {
        display: none;
    }
    .reframed-mobile .strip-hint-bar span { font-size: 0.8rem; color: var(--muted); }
    .reframed-mobile .reframed-desc {
        flex: 1;
        padding: 12px 0 24px;
        max-width: 70ch;
        margin: 0;
        width: 100%;
        text-align: left;
    }
    .reframed-mobile .reframed-desc .meta { font-size: 0.85rem; line-height: 1.6; margin-bottom: 16px; color: var(--muted); }
    .reframed-mobile .reframed-desc .meta strong { color: var(--fg); font-weight: 600; }
    .reframed-mobile .reframed-desc p { font-size: 0.85rem; line-height: 1.75; color: var(--muted2); margin: 0; }
    .reframed-mobile .strip::after { content: ""; flex: 0 0 clamp(24px, 6vw, 96px); }
    .reframed-mobile .lb_img { cursor: zoom-in; }

    .lightbox-mobile {
        position: fixed;
        inset: 0;
        display: none;
        z-index: 2000;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        touch-action: pan-y;
    }
    .lightbox-mobile.is_open { display: flex; }
    .lightbox-mobile .lb_backdrop { position: absolute; inset: 0; background: #000; cursor: zoom-out; }
    .lightbox-mobile .lb_inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        max-width: 100vw;
        max-height: 90vh;
        padding: 20px;
        overflow-x: hidden;
        overflow-y: auto;
        overscroll-behavior: contain;
        min-width: 0;
    }
    .lightbox-mobile .lb_view {
        max-height: calc(90vh - 80px);
        max-width: 90vw;
        width: auto;
        height: auto;
        object-fit: contain;
        flex-shrink: 0;
        pointer-events: none;
        user-select: none;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .lightbox-mobile .lb_controls { display: flex; align-items: center; justify-content: center; gap: 16px; }
    .lightbox-mobile .lb_btn {
        appearance: none;
        border: 0;
        background: transparent;
        color: #fff;
        font-size: 20px;
        min-width: 48px;
        min-height: 48px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .lightbox-mobile .lb_btn:hover { opacity: 0.8; }

    @media (max-width: 720px) {
        .reframed-mobile .strip { height: 38vh; gap: 24px; }
        .reframed-mobile figure.frame { height: 38vh; }
        .reframed-mobile .reframed-desc { padding: 12px 0 24px; }
    }
</style>

<script is:inline>
(function() {
    const isDesktop = () => window.innerWidth >= 769;

    function initDesktop() {
        const imgs = document.querySelectorAll(".reframed-desktop .lb_img");
        const lb = document.querySelector(".lightbox-desktop");
        const view = document.querySelector(".lightbox-desktop .lb_view");
        const prev = document.querySelector(".lightbox-desktop .lb_prev");
        const next = document.querySelector(".lightbox-desktop .lb_next");
        const closers = document.querySelectorAll(".lightbox-desktop [data-close='1']");
        if (!imgs.length || !lb || !view || !prev || !next) return;

        const sources = [...imgs].map(img => img.getAttribute("src"));
        let index = 0;

        function openAt(i) {
            index = (i + sources.length) % sources.length;
            view.src = sources[index];
            view.alt = "Reframed Still — frame " + String(index + 1).padStart(2, "0");
            lb.classList.add("is_open");
            lb.setAttribute("aria-hidden", "false");
            document.documentElement.style.overflow = "hidden";
        }
        function close() {
            lb.classList.remove("is_open");
            lb.setAttribute("aria-hidden", "true");
            view.src = "";
            document.documentElement.style.overflow = "";
        }
        function step(dir) { openAt(index + dir); }

        imgs.forEach((img, i) => img.addEventListener("click", () => openAt(i)));
        prev.addEventListener("click", () => step(-1));
        next.addEventListener("click", () => step(1));
        closers.forEach(el => el.addEventListener("click", close));

        document.addEventListener("keydown", (e) => {
            if (lb.classList.contains("is_open")) {
                if (e.key === "Escape") close();
                if (e.key === "ArrowLeft") step(-1);
                if (e.key === "ArrowRight") step(1);
                return;
            }
            const strip = document.getElementById("reframed-strip-desktop");
            if (strip && (e.key === "ArrowLeft" || e.key === "ArrowRight")) {
                strip.scrollBy({
                    left: e.key === "ArrowLeft" ? -280 : 280,
                    behavior: window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches ? "auto" : "smooth"
                });
            }
        });
    }

    function initMobile() {
        const imgs = document.querySelectorAll(".reframed-mobile .lb_img");
        const lb = document.getElementById("reframed-lightbox");
        const view = lb?.querySelector(".lb_view");
        const prev = lb?.querySelector(".lb_prev");
        const next = lb?.querySelector(".lb_next");
        const closers = lb ? lb.querySelectorAll("[data-close='1']") : [];
        if (!imgs.length || !lb || !view || !prev || !next) return;

        const sources = [...imgs].map(img => img.getAttribute("src"));
        let index = 0;

        function openAt(i) {
            index = (i + sources.length) % sources.length;
            view.src = sources[index];
            view.alt = "Reframed Still — frame " + String(index + 1).padStart(2, "0");
            lb.classList.add("is_open");
            lb.setAttribute("aria-hidden", "false");
            document.documentElement.style.overflow = "hidden";
            document.body.style.overflow = "hidden";
            window.dispatchEvent(new Event("lenis:pause"));
        }
        function close() {
            lb.classList.remove("is_open");
            lb.setAttribute("aria-hidden", "true");
            view.src = "";
            document.documentElement.style.overflow = "";
            document.body.style.overflow = "";
            window.dispatchEvent(new Event("lenis:resume"));
        }
        function step(dir) { openAt(index + dir); }

        imgs.forEach((img, i) => img.addEventListener("click", () => openAt(i)));
        prev.addEventListener("click", (e) => { e.stopPropagation(); step(-1); });
        next.addEventListener("click", (e) => { e.stopPropagation(); step(1); });
        closers.forEach(el => el.addEventListener("click", (e) => { e.stopPropagation(); close(); }));

        lb.addEventListener("click", (e) => { if (e.target === lb) close(); });

        let tx = 0;
        lb.addEventListener("touchstart", e => { tx = e.touches[0].clientX; }, { passive: true });
        lb.addEventListener("touchend", e => {
            const d = e.changedTouches[0].clientX - tx;
            if (Math.abs(d) > 50) step(d > 0 ? -1 : 1);
        }, { passive: true });

        document.addEventListener("keydown", (e) => {
            if (lb.classList.contains("is_open")) {
                if (e.key === "Escape") close();
                if (e.key === "ArrowLeft") step(-1);
                if (e.key === "ArrowRight") step(1);
                return;
            }
            const strip = document.getElementById("reframed-strip");
            if (strip && (e.key === "ArrowLeft" || e.key === "ArrowRight")) {
                strip.scrollBy({
                    left: e.key === "ArrowLeft" ? -280 : 280,
                    behavior: window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches ? "auto" : "smooth"
                });
            }
        });
    }

    initDesktop();
    initMobile();
})();
</script>

<script is:inline>
(function reframedHintBar() {
    function setup(hintId, stripId, defaultHint) {
        var hintEl = document.getElementById(hintId);
        var strip = document.getElementById(stripId);
        if (!hintEl || !strip) return;
        function getFrameHint(node) {
            var frame = node?.closest?.(".frame");
            return frame?.hasAttribute("data-hint") ? (frame.getAttribute("data-hint") || defaultHint) : null;
        }
        function setHint(hint) { hintEl.textContent = hint || defaultHint; }
        document.addEventListener("mouseover", function(e) {
            if (!strip.contains(e.target)) return;
            var h = getFrameHint(e.target);
            if (h) setHint(h);
        });
        document.addEventListener("mouseout", function(e) {
            if (!strip.contains(e.relatedTarget)) setHint(null);
            else { var h = getFrameHint(e.relatedTarget); setHint(h || null); }
        });
    }
    setup("reframed-hint-text-desktop", "reframed-strip-desktop", "Use ←/→ to scroll · Hover for a note");
    setup("reframed-hint-text", "reframed-strip", "Swipe or click to browse");
})();
</script>
